# Server Port Configuration
PORT=3000

# Environment Mode
NODE_ENV=production

# Persistent Database Connection (MongoDB URI)
# For local MongoDB container: mongodb://mongo:27017/connectx
# For cloud database: mongodb+srv://<username>:<password>@cluster.mongodb.net/connectx
MONGODB_URI=mongodb://127.0.0.1:27017/connectx

# Allowed CORS Origin (restrict to production domain)
CORS_ORIGIN=https://yourdomain.com
